# Copy this file to .env and fill only the providers you use.

# Optional provider selector. CLI --provider still takes precedence.
KEEL_PROVIDER=deepseek

# Recommended default. DeepSeek uses its Anthropic-compatible endpoint.
KEEL_DEEPSEEK_API_BASE=https://api.deepseek.com/anthropic
KEEL_DEEPSEEK_API_KEY=
KEEL_DEEPSEEK_MODEL=deepseek-v4-pro

# Optional right.codes shared key. Used by --provider openai and --provider anthropic when provider-specific keys are empty.
KEEL_RIGHT_CODES_API_KEY=

# Default OpenAI-compatible endpoint. Change this if you use another /responses-compatible service.
KEEL_OPENAI_API_BASE=https://www.right.codes/codex/v1
KEEL_OPENAI_API_KEY=
KEEL_OPENAI_MODEL=gpt-5.4

# Default Anthropic-compatible endpoint. Can reuse KEEL_RIGHT_CODES_API_KEY when your gateway shares one key.
KEEL_ANTHROPIC_API_BASE=https://www.right.codes/claude/v1
KEEL_ANTHROPIC_API_KEY=
KEEL_ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional comma-separated extra env names to redact from traces and reports.
KEEL_SECRET_ENV_NAMES=
